        "liquid_Q3DD9i": {
          "type": "liquid",
          "settings": {
            "liquid": "<div style=\"max-width: 600px; margin: 0 auto; padding: 20px 0;\">\n  <h2 style=\"text-align: center; font-size: 20px; font-weight: 700; margin-bottom: 16px; color: #1a1a1a;\">\n  Résultat Après 7 Jours<br>Zéro Sensibilité\n</h2>\n\n  <div id=\"slider-container\" style=\"\n    position: relative;\n    width: 100%;\n    overflow: hidden;\n    border-radius: 16px;\n    cursor: ew-resize;\n    user-select: none;\n  \">\n    <!-- Image APRÈS (fond) -->\n    <img \n      id=\"img-after\"\n      src=\"https://cdn.shopify.com/s/files/1/0814/7897/5709/files/ChatGPT_Image_27_fevr._2026_03_44_11_430x.png?v=1772181867#\"\n      style=\"width: 100%; display: block;\"\n      draggable=\"false\"\n    />\n\n    <!-- Image AVANT (par-dessus, clippée) -->\n    <div id=\"before-wrap\" style=\"\n      position: absolute;\n      top: 0; left: 0;\n      width: 50%;\n      height: 100%;\n      overflow: hidden;\n    \">\n      <img \n        src=\"https://cdn.shopify.com/s/files/1/0814/7897/5709/files/ChatGPT_Image_27_fevr._2026_03_42_45_430x.png?v=1772181867#\"\n        style=\"width: 100vw; max-width: 600px; display: block;\"\n        draggable=\"false\"\n      />\n    </div>\n\n    <!-- Labels AVANT / APRÈS -->\n    <div style=\"\n      position: absolute; top: 12px; left: 12px;\n      background: rgba(0,0,0,0.55);\n      color: white; font-size: 12px; font-weight: 700;\n      padding: 4px 10px; border-radius: 20px;\n    \">AVANT</div>\n\n    <div style=\"\n      position: absolute; top: 12px; right: 12px;\n      background: #7c3aed;\n      color: white; font-size: 12px; font-weight: 700;\n      padding: 4px 10px; border-radius: 20px;\n    \">APRÈS</div>\n\n    <!-- Ligne de séparation -->\n    <div id=\"divider\" style=\"\n      position: absolute;\n      top: 0; left: 50%;\n      width: 2px; height: 100%;\n      background: white;\n      transform: translateX(-50%);\n    \"></div>\n\n    <!-- Bouton curseur -->\n    <div id=\"handle\" style=\"\n      position: absolute;\n      top: 50%; left: 50%;\n      transform: translate(-50%, -50%);\n      width: 44px; height: 44px;\n      background: white;\n      border-radius: 50%;\n      box-shadow: 0 2px 12px rgba(0,0,0,0.3);\n      display: flex;\n      align-items: center;\n      justify-content: center;\n      font-size: 18px;\n      cursor: ew-resize;\n    \">⇔</div>\n  </div>\n\n  <p style=\"text-align: center; font-size: 13px; color: #7c3aed; font-weight: 600; margin-top: 12px;\">\n    ← Fais glisser pour voir la transformation →\n  </p>\n</div>\n\n<script>\n(function() {\n  const container = document.getElementById('slider-container');\n  const beforeWrap = document.getElementById('before-wrap');\n  const divider = document.getElementById('divider');\n  const handle = document.getElementById('handle');\n  let dragging = false;\n\n  function setPosition(x) {\n    const rect = container.getBoundingClientRect();\n    let pct = (x - rect.left) / rect.width * 100;\n    pct = Math.min(Math.max(pct, 2), 98);\n    beforeWrap.style.width = pct + '%';\n    divider.style.left = pct + '%';\n    handle.style.left = pct + '%';\n  }\n\n  container.addEventListener('mousedown', (e) => { dragging = true; setPosition(e.clientX); });\n  window.addEventListener('mouseup', () => dragging = false);\n  window.addEventListener('mousemove', (e) => { if (dragging) setPosition(e.clientX); });\n\n  container.addEventListener('touchstart', (e) => { dragging = true; setPosition(e.touches[0].clientX); });\n  window.addEventListener('touchend', () => dragging = false);\n  window.addEventListener('touchmove', (e) => { if (dragging) setPosition(e.touches[0].clientX); });\n})();\n</script>"
          }
        }
