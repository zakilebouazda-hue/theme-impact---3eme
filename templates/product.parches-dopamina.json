 color: #111;\">Efecto en 30 min</span>\n    </div>\n\n    <div style=\"display: flex; align-items: center; gap: 8px; padding: 4px 0;\">\n      <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#FACC15\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M22 11.08V12a10 10 0 1 1-5.93-9.14\"/><polyline points=\"22 4 12 14.01 9 11.01\"/></svg>\n      <span style=\"font-size: 12px; font-weight: 700; color: #111;\">8h energía estable</span>\n    </div>\n\n    <div style=\"display: flex; align-items: center; gap: 8px; padding: 4px 0;\">\n      <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#FACC15\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M22 11.08V12a10 10 0 1 1-5.93-9.14\"/><polyline points=\"22 4 12 14.01 9 11.01\"/></svg>\n      <span style=\"font-size: 12px; font-weight: 700; color: #111;\">Invisible bajo la ropa</span>\n    </div>\n\n    <div style=\"display: flex; align-items: center; gap: 8px; padding: 4px 0;\">\n      <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#FACC15\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M22 11.08V12a10 10 0 1 1-5.93-9.14\"/><polyline points=\"22 4 12 14.01 9 11.01\"/></svg>\n      <span style=\"font-size: 12px; font-weight: 700; color: #111;\">Ingredientes naturales</span>\n    </div>\n\n  </div>\n</div>",
