            "liquid": "<div style=\"padding: 10px 0; margin: 10px 0;\">\n  <!-- LOGOS PAIEMENT -->\n  <div style=\"display: flex; justify-content: center; align-items: center; gap: 6px; flex-wrap: wrap;\">\n    <img src=\"https://cdn.shopify.com/s/files/1/0814/7897/5709/files/Capture_d_ecran_le_2026-03-11_a_16.13.46_430x.png?v=1773260033\" style=\"height: 30px; width: auto;\" alt=\"Métodos de pago\" />\n  </div>\n</div>\n\n<div style=\"padding: 10px 0; margin: 10px 0;\">\n  <!-- GARANTIE + STOCK -->\n  <div style=\"display: flex; justify-content: center; align-items: center; gap: 8px; margin-bottom: 12px; flex-wrap: nowrap;\">\n    <div style=\"display: flex; align-items: center; gap: 4px; background: #f0fdf4; border: 1px solid #86efac; border-radius: 6px; padding: 4px 8px;\">\n      <span style=\"font-size: 11px;\">🛡️</span>\n      <span style=\"font-size: 10px; font-weight: 600; color: #166534; white-space: nowrap;\">Garantía 30 días — Devolución Total</span>\n    </div>\n    <div style=\"display: flex; align-items: center; gap: 4px; background: #fff7ed; border: 1px solid #fdba74; border-radius: 6px; padding: 4px 8px;\">\n      <span style=\"font-size: 11px;\">⏰</span>\n      <span style=\"font-size: 10px; font-weight: 600; color: #c2410c; white-space: nowrap;\">¡STOCK LIMITADO!</span>\n    </div>\n  </div>\n</div>"
