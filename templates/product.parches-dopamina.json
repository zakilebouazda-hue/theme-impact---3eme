    "custom_liquid_wWirjb": {
      "type": "custom-liquid",
      "name": "Custom Liquid",
      "settings": {
        "full_width": true,
        "remove_vertical_spacing": true,
        "remove_horizontal_spacing": true,
        "liquid": "<div style=\"margin: 24px 0;\">\n\n  <!-- TITRE -->\n  <div style=\"text-align: center; margin-bottom: 20px;\">\n    <p style=\"margin: 0 0 6px; font-size: 11px; font-weight: 700; color: #111; letter-spacing: 1.5px; text-transform: uppercase; background: #FACC15; display: inline-block; padding: 3px 10px; border-radius: 4px;\">¿Cómo funciona?</p>\n    <h2 style=\"margin: 8px 0 0; font-size: 20px; font-weight: 900; color: #111; line-height: 1.3;\">La ciencia detrás del parche</h2>\n  </div>\n\n  <!-- CAROUSEL WRAPPER -->\n  <div style=\"position: relative; border-radius: 12px; overflow: hidden;\">\n\n    <!-- SLIDES -->\n    <div id=\"how-track\" style=\"display: flex; transition: transform 0.4s ease; will-change: transform;\">\n\n      <!-- SLIDE 1 -->\n      <div style=\"min-width: 100%; box-sizing: border-box; border-radius: 12px; overflow: hidden; background: #f9fafb; border: 1px solid #e5e7eb;\">\n        <img src=\"https://cdn.shopify.com/s/files/1/0814/7897/5709/files/Design_sans_titre_4_430x.png?v=1773895088\"\n          alt=\"Aplicar parche NELORYA\"\n          style=\"width: 100%; display: block; object-fit: cover;\" />\n        <div style=\"padding: 14px 16px;\">\n          <div style=\"display: flex; align-items: center; gap: 8px; margin-bottom: 6px;\">\n            <span style=\"background: #FACC15; color: #111; font-size: 11px; font-weight: 900; width: 22px; height: 22px; border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0;\">1</span>\n            <p style=\"margin: 0; font-size: 14px; font-weight: 800; color: #111;\">Aplica en 3 segundos</p>\n          </div>\n          <p style=\"margin: 0; font-size: 12px; color: #6b7280; line-height: 1.6; padding-left: 30px;\">Pega el parche en el antebrazo cada mañana. Sin agua, sin pastillero, sin rutina complicada.</p>\n        </div>\n      </div>\n\n      <!-- SLIDE 2 -->\n      <div style=\"min-width: 100%; box-sizing: border-box; border-radius: 12px; overflow: hidden; background: #f9fafb; border: 1px solid #e5e7eb;\">\n        <img src=\"https://cdn.shopify.com/s/files/1/0814/7897/5709/files/Gemini_Generated_Image_1u7hhl1u7hhl1u7h_430x.png?v=1773895088\"\n          alt=\"Absorción transdérmica NELORYA\"\n          style=\"width: 100%; display: block; object-fit: cover;\" />\n        <div style=\"padding: 14px 16px;\">\n          <div style=\"display: flex; align-items: center; gap: 8px; margin-bottom: 6px;\">\n            <span style=\"background: #FACC15; color: #111; font-size: 11px; font-weight: 900; width: 22px; height: 22px; border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0;\">2</span>\n            <p style=\"margin: 0; font-size: 14px; font-weight: 800; color: #111;\">Directo al torrente sanguíneo</p>\n          </div>\n          <p style=\"margin: 0; font-size: 12px; color: #6b7280; line-height: 1.6; padding-left: 30px;\">A diferencia de las cápsulas, la tecnología transdérmica bypasea el sistema digestivo. Efecto en 30 minutos, sin pérdidas de absorción.</p>\n        </div>\n      </div>\n\n      <!-- SLIDE 3 -->\n      <div style=\"min-width: 100%; box-sizing: border-box; border-radius: 12px; overflow: hidden; background: #f9fafb; border: 1px solid #e5e7eb;\">\n        <img src=\"https://cdn.shopify.com/s/files/1/0814/7897/5709/files/Design_sans_titre_5_430x.png?v=1773895500\"\n          alt=\"Energía estable 8h NELORYA\"\n          style=\"width: 100%; display: block; object-fit: cover;\" />\n        <div style=\"padding: 14px 16px;\">\n          <div style=\"display: flex; align-items: center; gap: 8px; margin-bottom: 6px;\">\n            <span style=\"background: #FACC15; color: #111; font-size: 11px; font-weight: 900; width: 22px; height: 22px; border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0;\">3</span>\n            <p style=\"margin: 0; font-size: 14px; font-weight: 800; color: #111;\">8h de energía estable</p>\n          </div>\n          <p style=\"margin: 0; font-size: 12px; color: #6b7280; line-height: 1.6; padding-left: 30px;\">Sin picos, sin crash a las 15h. Rendimiento constante durante toda la jornada laboral — sin un solo café extra.</p>\n        </div>\n      </div>\n\n    </div>\n  </div>\n\n  <!-- DOTS -->\n  <div style=\"display: flex; justify-content: center; gap: 6px; margin-top: 12px;\" id=\"how-dots\">\n    <span onclick=\"howGoTo(0)\" style=\"width: 8px; height: 8px; border-radius: 50%; background: #FACC15; cursor: pointer; display: block;\"></span>\n    <span onclick=\"howGoTo(1)\" style=\"width: 8px; height: 8px; border-radius: 50%; background: #d1d5db; cursor: pointer; display: block;\"></span>\n    <span onclick=\"howGoTo(2)\" style=\"width: 8px; height: 8px; border-radius: 50%; background: #d1d5db; cursor: pointer; display: block;\"></span>\n  </div>\n\n</div>\n\n<script>\n  var howCurrent = 0;\n  var howTotal = 3;\n\n  function howGoTo(index) {\n    howCurrent = index;\n    document.getElementById('how-track').style.transform = 'translateX(-' + (howCurrent * 100) + '%)';\n    var dots = document.getElementById('how-dots').children;\n    for (var i = 0; i < dots.length; i++) {\n      dots[i].style.background = i === howCurrent ? '#FACC15' : '#d1d5db';\n    }\n  }\n\n  function howSlide(dir) {\n    howCurrent = (howCurrent + dir + howTotal) % howTotal;\n    howGoTo(howCurrent);\n  }\n\n  var howStartX = 0;\n  var howTrack = document.getElementById('how-track');\n  howTrack.addEventListener('touchstart', function(e) { howStartX = e.touches[0].clientX; });\n  howTrack.addEventListener('touchend', function(e) {\n    var diff = howStartX - e.changedTouches[0].clientX;\n    if (Math.abs(diff) > 40) howSlide(diff > 0 ? 1 : -1);\n  });\n</script>",
        "background": "",
        "background_gradient": "",
        "text_color": ""
      }
    },
    "custom_liquid_tMfpE4": {
      "type": "custom-liquid",
      "name": "Custom Liquid",
      "settings": {
        "full_width": true,
        "remove_vertical_spacing": true,
        "remove_horizontal_spacing": true,
        "liquid": "<div style=\"margin: 24px 0;\">\n\n  <!-- TITRE -->\n  <div style=\"text-align: center; margin-bottom: 16px;\">\n    <p style=\"margin: 0 0 6px; font-size: 11px; font-weight: 700; color: #111; letter-spacing: 1.5px; text-transform: uppercase; background: #FACC15; display: inline-block; padding: 3px 10px; border-radius: 4px;\">¿Por qué NELORYA™?</p>\n    <h2 style=\"margin: 8px 0 0; font-size: 20px; font-weight: 900; color: #111; line-height: 1.3;\">No todos los impulsos de energía son iguales</h2>\n  </div>\n\n  <!-- TABLE MOBILE-FIRST -->\n  <div style=\"border-radius: 12px; overflow: hidden; border: 1px solid #e5e7eb;\">\n    <table style=\"width: 100%; border-collapse: collapse; table-layout: fixed;\">\n\n      <!-- HEADER -->\n      <thead>\n        <tr>\n          <th style=\"padding: 10px 6px; text-align: left; background: #f9fafb; font-size: 10px; color: #6b7280; font-weight: 600; width: 36%;\"></th>\n          <th style=\"padding: 10px 4px; text-align: center; background: #111; color: #FACC15; font-size: 10px; font-weight: 900; width: 16%;\">NELORYA™</th>\n          <th style=\"padding: 10px 4px; text-align: center; background: #f9fafb; color: #6b7280; font-size: 10px; font-weight: 600; width: 16%;\">Café</th>\n          <th style=\"padding: 10px 4px; text-align: center; background: #f9fafb; color: #6b7280; font-size: 10px; font-weight: 600; width: 16%;\">E. Drink</th>\n          <th style=\"padding: 10px 4px; text-align: center; background: #f9fafb; color: #6b7280; font-size: 10px; font-weight: 600; width: 16%;\">Cápsulas</th>\n        </tr>\n      </thead>\n\n      <tbody>\n        <tr style=\"border-top: 1px solid #f3f4f6;\">\n          <td style=\"padding: 10px 8px; font-size: 11px; font-weight: 700; color: #111;\">Sin cafeína</td>\n          <td style=\"padding: 10px 4px; text-align: center; background: #1a1a1a; color: #FACC15; font-size: 14px; font-weight: 900;\">✓</td>\n          <td style=\"padding: 10px 4px; text-align: center; color: #ef4444; font-size: 14px;\">✕</td>\n          <td style=\"padding: 10px 4px; text-align: center; color: #ef4444; font-size: 14px;\">✕</td>\n          <td style=\"padding: 10px 4px; text-align: center; color: #9ca3af; font-size: 14px;\">~</td>\n        </tr>\n\n        <tr style=\"border-top: 1px solid #f3f4f6;\">\n          <td style=\"padding: 10px 8px; font-size: 11px; font-weight: 700; color: #111;\">Sin crash</td>\n          <td style=\"padding: 10px 4px; text-align: center; background: #1a1a1a; color: #FACC15; font-size: 14px; font-weight: 900;\">✓</td>\n          <td style=\"padding: 10px 4px; text-align: center; color: #ef4444; font-size: 14px;\">✕</td>\n          <td style=\"padding: 10px 4px; text-align: center; color: #ef4444; font-size: 14px;\">✕</td>\n          <td style=\"padding: 10px 4px; text-align: center; color: #9ca3af; font-size: 14px;\">~</td>\n        </tr>\n\n        <tr style=\"border-top: 1px solid #f3f4f6;\">\n          <td style=\"padding: 10px 8px; font-size: 11px; font-weight: 700; color: #111;\">Efecto en 30 min</td>\n          <td style=\"padding: 10px 4px; text-align: center; background: #1a1a1a; color: #FACC15; font-size: 14px; font-weight: 900;\">✓</td>\n          <td style=\"padding: 10px 4px; text-align: center; color: #FACC15; font-size: 14px;\">✓</td>\n          <td style=\"padding: 10px 4px; text-align: center; color: #FACC15; font-size: 14px;\">✓</td>\n          <td style=\"padding: 10px 4px; text-align: center; color: #ef4444; font-size: 14px;\">✕</td>\n        </tr>\n\n        <tr style=\"border-top: 1px solid #f3f4f6;\">\n          <td style=\"padding: 10px 8px; font-size: 11px; font-weight: 700; color: #111;\">8h estable</td>\n          <td style=\"padding: 10px 4px; text-align: center; background: #1a1a1a; color: #FACC15; font-size: 14px; font-weight: 900;\">✓</td>\n          <td style=\"padding: 10px 4px; text-align: center; color: #ef4444; font-size: 14px;\">✕</td>\n          <td style=\"padding: 10px 4px; text-align: center; color: #ef4444; font-size: 14px;\">✕</td>\n          <td style=\"padding: 10px 4px; text-align: center; color: #9ca3af; font-size: 14px;\">~</td>\n        </tr>\n\n        <tr style=\"border-top: 1px solid #f3f4f6;\">\n          <td style=\"padding: 10px 8px; font-size: 11px; font-weight: 700; color: #111;\">Sin pastillas</td>\n          <td style=\"padding: 10px 4px; text-align: center; background: #1a1a1a; color: #FACC15; font-size: 14px; font-weight: 900;\">✓</td>\n          <td style=\"padding: 10px 4px; text-align: center; color: #FACC15; font-size: 14px;\">✓</td>\n          <td style=\"padding: 10px 4px; text-align: center; color: #FACC15; font-size: 14px;\">✓</td>\n          <td style=\"padding: 10px 4px; text-align: center; color: #ef4444; font-size: 14px;\">✕</td>\n        </tr>\n\n        <tr style=\"border-top: 1px solid #f3f4f6;\">\n          <td style=\"padding: 10px 8px; font-size: 11px; font-weight: 700; color: #111;\">Discreto oficina</td>\n          <td style=\"padding: 10px 4px; text-align: center; background: #1a1a1a; color: #FACC15; font-size: 14px; font-weight: 900;\">✓</td>\n          <td style=\"padding: 10px 4px; text-align: center; color: #9ca3af; font-size: 14px;\">~</td>\n          <td style=\"padding: 10px 4px; text-align: center; color: #ef4444; font-size: 14px;\">✕</td>\n          <td style=\"padding: 10px 4px; text-align: center; color: #9ca3af; font-size: 14px;\">~</td>\n        </tr>\n\n        <tr style=\"border-top: 1px solid #f3f4f6;\">\n          <td style=\"padding: 10px 8px; font-size: 11px; font-weight: 700; color: #111;\">Sin ansiedad</td>\n          <td style=\"padding: 10px 4px; text-align: center; background: #1a1a1a; color: #FACC15; font-size: 14px; font-weight: 900;\">✓</td>\n          <td style=\"padding: 10px 4px; text-align: center; color: #ef4444; font-size: 14px;\">✕</td>\n          <td style=\"padding: 10px 4px; text-align: center; color: #ef4444; font-size: 14px;\">✕</td>\n          <td style=\"padding: 10px 4px; text-align: center; color: #9ca3af; font-size: 14px;\">~</td>\n        </tr>\n      </tbody>\n\n    </table>\n  </div>\n\n  <!-- LÉGENDE -->\n  <div style=\"display: flex; justify-content: center; gap: 16px; margin-top: 10px;\">\n    <span style=\"font-size: 10px; color: #6b7280;\"><span style=\"color: #FACC15; font-weight: 700;\">✓</span> Sí</span>\n    <span style=\"font-size: 10px; color: #6b7280;\"><span style=\"color: #ef4444;\">✕</span> No</span>\n    <span style=\"font-size: 10px; color: #9ca3af;\">~ Depende</span>\n  </div>\n\n</div>",
